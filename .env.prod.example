# ==============================================================================
# Database Config
# ==============================================================================
# Format django-environ : postgres://USER:PASSWORD@HOST:PORT/DB_NAME
# Le host est "db" car c'est le nom du service dans docker-compose.yml
# Le port interne du conteneur PostgreSQL est 5432 (pas 5433 qui est le port mappé sur l'hôte)
DATABASE_URL=postgres://jangubi_user:jangubi_pass@db:5432/jangubi

# Redis : utilisé pour le cache Django (django-redis)
REDIS_URL=redis://redis:6379/1

# ==============================================================================
# Django Config + Traefik Reverse Proxy
# ==============================================================================
APP_DOMAIN=https://jangubi.thenexcom.com
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.django.production
SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
ALLOWED_HOSTS=jangubi.thenexcom.com,django,localhost
SESSION_COOKIE_SECURE=True
SECURE_CONTENT_TYPE_NOSNIFF=True

# Traefik reverse proxy en HTTP (MVP); passe à True une fois HTTPS opérationnel
SECURE_SSL_REDIRECT=True
TRAEFIK_ACME_EMAIL=admin@jangubi.thenexcom.com

# CORS pour frontend Vercel + mobile
# Mettre True si tu veux temporairement tout autoriser
CORS_ALLOW_ALL_ORIGINS=False
DJANGO_CORS_ORIGIN_WHITELIST=https://jangubi.thenexcom.com,https://*.vercel.app
# Option pour previews Vercel (regex)
CORS_ALLOWED_ORIGIN_REGEXES=^https:\/\/[a-zA-Z0-9-]+\.vercel\.app$
# Requis pour les requêtes unsafe (POST/PUT/DELETE) côté web avec CSRF/session via Traefik
CSRF_TRUSTED_ORIGINS=https://jangubi.thenexcom.com,https://*.vercel.app
# Celery Broker : RabbitMQ (nom du service docker-compose)
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# URLs de base (utilisées par cors.py)
DJANGO_BASE_BACKEND_URL=https://jangubi.thenexcom.com
DJANGO_BASE_FRONTEND_URL=https://jangubi.thenexcom.com

# Sessions/JWT (web + mobile)
SESSION_COOKIE_AGE=1209600
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_NAME=sessionid
SESSION_COOKIE_SAMESITE=Lax
CSRF_USE_SESSIONS=True

JWT_EXPIRATION_DELTA_SECONDS=604800
JWT_AUTH_COOKIE=jwt
JWT_AUTH_COOKIE_SAMESITE=Lax
JWT_AUTH_HEADER_PREFIX=Bearer

# Logging/Debug
DEBUG_TOOLBAR_ENABLED=False
LOGGING_FORMAT=json

# ==============================================================================
# Bucket / Stockage S3 (MinIO en local)
# ==============================================================================
# En local, on utilise le stockage "local" par défaut.
# Décommentez et configurez si vous passez en mode S3 (FILE_UPLOAD_STORAGE=s3)
FILE_UPLOAD_STRATEGY=standard
FILE_UPLOAD_STORAGE=s3
FILE_MAX_SIZE=10485760

AWS_S3_ACCESS_KEY_ID=minioadmin
AWS_S3_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=jangubi-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_DEFAULT_ACL=private
AWS_PRESIGNED_EXPIRY=10
AWS_S3_CUSTOM_DOMAIN=

# ==============================================================================
# Docker Compose Config (utilisées par les services db et minio)
# ==============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
POSTGRES_DB=jangubi
POSTGRES_USER=jangubi_user
POSTGRES_PASSWORD=jangubi_pass

# ==============================================================================
# Sentry (désactivé en local, laisser vide)
# ==============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ==============================================================================
# Gemini / RAG
# ==============================================================================
GEMINI_API_KEY=AIzaSyBr8wRtVjJSe66vgOYn9qHZwhp1uREf-bs
EMBEDDING_PROVIDER=gemini
PGVECTOR_ENABLED=True

